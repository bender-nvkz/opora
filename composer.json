{
  "name": "bender-nvkz/opora",
  "description": "Российская open-source PIM/MDM/DAM платформа",
  "type": "library",
  "version": "0.1.0",
  "license": "AGPL-3.0-only",
  "keywords": ["pim", "mdm", "dam", "yii3", "php84"],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
    "php": "^8.4",
    "ext-pdo": "*",
    "ext-pdo_pgsql": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-intl": "*",
    "ext-openssl": "*",
    "ext-fileinfo": "*",
    "yiisoft/app": "^1.4.0",
    "yiisoft/config": "^1.6.2",
    "yiisoft/di": "^1.4.1",
    "yiisoft/router": "^4.0.2",
    "yiisoft/router-fastroute": "^4.0.3",
    "yiisoft/middleware-dispatcher": "^5.4.0",
    "yiisoft/request-body-parser": "^1.2.1",
    "yiisoft/yii-middleware": "^1.1.2",
    "yiisoft/log": "^2.2.1",
    "yiisoft/log-target-file": "^3.1.0",
    "yiisoft/db": "^2.0.1",
    "yiisoft/db-pgsql": "^2.0.1",
    "yiisoft/yii-cycle": "2.0.x-dev",
    "cycle/orm": "^v2.16.1",
    "cycle/database": "^2.17.0",
    "cycle/migrations": "^v4.2.6",
    "cycle/schema-builder": "^v2.11.2",
    "cycle/entity-behavior": "^1.7.1",
    "yiisoft/queue": "3.0.x-dev",
    "yiisoft/yii-console": "^2.4.2",
    "yiisoft/cache": "^3.2.0",
    "yiisoft/cache-file": "^3.2.0",
    "yiisoft/validator": "^2.5.1",
    "yiisoft/data": "^2.0.0",
    "yiisoft/data-db": "^1.0",
    "yiisoft/translator": "^3.2.1",
    "yiisoft/http": "^1.3.0",
    "yiisoft/auth": "^3.2.1",
    "league/flysystem": "^3.34.0",
    "league/flysystem-local": "^3.31.0",
    "symfony/workflow": "^v7.4.9",
    "symfony/lock": "^v7.4.9",
    "psr/http-message": "^2.0",
    "psr/http-server-middleware": "^1.0",
    "psr/log": "^3.0",
    "psr/container": "^2.0",
    "psr/simple-cache": "^3.0",
    "psr/event-dispatcher": "^1.0",
    "ramsey/uuid": "^4.9.2",
    "webmozart/assert": "^2.3.0",
    "brick/math": "^0.12"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.1",
    "phpstan/phpstan": "^2.1",
    "phpstan/phpstan-strict-rules": "^2.0",
    "phpstan/phpstan-phpunit": "^2.0",
    "friendsofphp/php-cs-fixer": "^3.68",
    "rector/rector": "^2.0",
    "fakerphp/faker": "^1.24",
    "yiisoft/var-dumper": "^1.7",
    "roave/security-advisories": "dev-latest"
  },
  "autoload": {
    "psr-4": {
      "Opora\\App\\": "src/App/",
      "Opora\\Core\\": "packages/core/src/",
      "Opora\\Domain\\": "src/Domain/",
      "Opora\\Infrastructure\\": "src/Infrastructure/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Opora\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "cs-fix": "php-cs-fixer fix",
    "cs-check": "php-cs-fixer fix --dry-run --diff",
    "stan": "phpstan analyse",
    "rector-check": "rector process --dry-run",
    "rector-fix": "rector process",
    "test": "phpunit",
    "test-unit": "phpunit --testsuite Unit",
    "test-integration": "phpunit --testsuite Integration",
    "ci": [
      "@cs-check",
      "@stan",
      "@rector-check",
      "@test"
    ]
  },
  "config": {
    "allow-plugins": {
      "yiisoft/config": true
    },
    "sort-packages": true,
    "optimize-autoloader": true
  },
  "extra": {
    "config-plugin": {
      "params": [
        "config/params/common.php",
        "?config/params/local.php"
      ],
      "common": [
        "config/common/container.php",
        "config/common/events.php"
      ],
      "web": [
        "$common",
        "config/web/container.php",
        "config/web/middleware.php",
        "config/web/routes.php"
      ],
      "console": [
        "$common",
        "config/console/container.php"
      ]
    }
  }
}
