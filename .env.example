# ═══════════════════════════════════════════════════════════════════
# Опора — шаблон переменных окружения
# Скопировать в .env: cp .env.example .env
# .env НЕ коммитится в git (добавлен в .gitignore)
# ═══════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────
# Приложение
# ─────────────────────────────────────────────────────────────────

# Окружение: dev | test | prod
APP_ENV=dev

# Включить debug-режим (true только в dev!)
APP_DEBUG=true

# Секретный ключ приложения — минимум 32 символа, случайный
# Генерация: openssl rand -hex 32
APP_SECRET=change-me-to-random-32-char-secret-here

# Имя приложения (используется в email-уведомлениях)
APP_NAME="Опора PIM"

# URL приложения (без trailing slash)
APP_URL=http://localhost:8080

# ─────────────────────────────────────────────────────────────────
# База данных PostgreSQL
# ─────────────────────────────────────────────────────────────────

# DSN строка подключения для PDO
# Формат: pgsql:host=HOST;port=PORT;dbname=DATABASE
DB_DSN=pgsql:host=postgres;port=5432;dbname=opora

# Имя пользователя БД
DB_USERNAME=opora

# Пароль пользователя БД
DB_PASSWORD=opora_dev_password

# Имя базы данных
DB_DATABASE=opora

# Хост базы данных (для прямых подключений вне Docker)
DB_HOST=postgres

# Порт базы данных
DB_PORT=5432

# Размер connection pool (для long-running workers)
DB_POOL_SIZE=10

# ─────────────────────────────────────────────────────────────────
# Очередь задач (yiisoft/queue)
# ─────────────────────────────────────────────────────────────────

# DSN для очереди (использует ту же БД через advisory locks)
QUEUE_DSN=pgsql:host=postgres;port=5432;dbname=opora

# Количество воркеров очереди
QUEUE_WORKERS=2

# Таймаут обработки задачи в секундах
QUEUE_TIMEOUT=300

# ─────────────────────────────────────────────────────────────────
# Кэш
# ─────────────────────────────────────────────────────────────────

# Директория для file-based кэша (по умолчанию, без Redis)
CACHE_DIR=/app/runtime/cache

# TTL кэша схемы в секундах (3600 = 1 час)
SCHEMA_CACHE_TTL=3600

# ─────────────────────────────────────────────────────────────────
# Логирование
# ─────────────────────────────────────────────────────────────────

# Директория для логов
LOG_DIR=/app/runtime/logs

# Уровень логирования: debug | info | notice | warning | error | critical
LOG_LEVEL=debug

# Формат логов: json (prod) | text (dev)
LOG_FORMAT=text

# ─────────────────────────────────────────────────────────────────
# Хранилище файлов (Flysystem)
# ─────────────────────────────────────────────────────────────────

# Адаптер хранилища: local | s3 | yandex_s3 | minio
STORAGE_ADAPTER=local

# Директория для локального хранилища
STORAGE_LOCAL_PATH=/app/runtime/storage

# S3-совместимое хранилище (если STORAGE_ADAPTER=s3/yandex_s3/minio)
STORAGE_S3_KEY=
STORAGE_S3_SECRET=
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=ru-central1
STORAGE_S3_ENDPOINT=https://storage.yandexcloud.net

# ─────────────────────────────────────────────────────────────────
# Email
# ─────────────────────────────────────────────────────────────────

# SMTP хост (в dev использовать mailpit: localhost:1025)
MAIL_HOST=mailpit

# SMTP порт
MAIL_PORT=1025

# SMTP шифрование: none | tls | ssl (в dev — none для mailpit)
MAIL_ENCRYPTION=none

# SMTP имя пользователя (пустое для mailpit)
MAIL_USERNAME=

# SMTP пароль (пустое для mailpit)
MAIL_PASSWORD=

# Email отправителя по умолчанию
MAIL_FROM_ADDRESS=noreply@opora.dev

# Имя отправителя по умолчанию
MAIL_FROM_NAME="Опора PIM"

# ─────────────────────────────────────────────────────────────────
# Embedding-провайдеры (для semantic search, Этап 4)
# ─────────────────────────────────────────────────────────────────

# Активный провайдер: gigachat | yandexgpt | e5_multilingual | bge_m3 | openai
EMBEDDING_PROVIDER=e5_multilingual

# GigaChat
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# YandexGPT
YANDEX_API_KEY=
YANDEX_FOLDER_ID=

# OpenAI (для сред, где доступен)
OPENAI_API_KEY=

# ─────────────────────────────────────────────────────────────────
# MCP сервер (Этап 9)
# ─────────────────────────────────────────────────────────────────

# Порт MCP сервера
MCP_PORT=3100

# Токен для MCP-аутентификации (генерировать: openssl rand -hex 32)
MCP_SECRET_TOKEN=

# ─────────────────────────────────────────────────────────────────
# Безопасность
# ─────────────────────────────────────────────────────────────────

# Время жизни auth-токена в секундах (86400 = 24 часа)
AUTH_TOKEN_TTL=86400

# Максимальное количество попыток входа до блокировки
AUTH_MAX_ATTEMPTS=5

# Время блокировки после исчерпания попыток (в секундах)
AUTH_LOCKOUT_DURATION=900

# Разрешённые CORS-origins (запятая — разделитель, * — запрещено в prod)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# ─────────────────────────────────────────────────────────────────
# Dev-утилиты (не использовать в prod)
# ─────────────────────────────────────────────────────────────────

# pgAdmin URL (только dev, запускается через: docker compose --profile tools up)
PGADMIN_URL=http://localhost:5050

# Mailpit URL (только dev, запускается через: docker compose --profile tools up)
MAILPIT_URL=http://localhost:8025
