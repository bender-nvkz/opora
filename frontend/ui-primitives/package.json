{
  "name": "@opora/ui-primitives",
  "version": "0.0.1",
  "private": false,
  "description": "Опора примитивы UI — обёртки над Radix UI с design tokens",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o .storybook-build",
    "clean": "rm -rf dist .storybook-build"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "@opora/design-tokens": "workspace:*",
    "@radix-ui/react-dialog": "1.1.4",
    "@radix-ui/react-dropdown-menu": "2.1.4",
    "@radix-ui/react-select": "2.1.4",
    "@radix-ui/react-tabs": "1.1.3",
    "@radix-ui/react-toast": "1.2.4",
    "@radix-ui/react-tooltip": "1.1.6",
    "@radix-ui/react-checkbox": "1.1.3",
    "@radix-ui/react-switch": "1.1.2",
    "@radix-ui/react-separator": "1.1.1",
    "@radix-ui/react-avatar": "1.1.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "tailwind-merge": "2.6.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "8.4.7",
    "@storybook/addon-essentials": "8.4.7",
    "@storybook/addon-interactions": "8.4.7",
    "@storybook/addon-themes": "8.4.7",
    "@storybook/react": "8.4.7",
    "@storybook/react-vite": "8.4.7",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "storybook": "8.4.7",
    "typescript": "5.7.2",
    "vite": "6.0.7"
  }
}
