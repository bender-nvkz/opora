{
    "name": "opora/core",
    "description": "Opora PIM — core package: bootstrapping, DI, middleware pipeline, console runner, config, logging, folders",
    "type": "library",
    "license": "AGPL-3.0-only",
    "keywords": ["pim", "mdm", "dam", "yii3", "php84"],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.4",

        "psr/http-message": "^2.0",
        "psr/http-server-middleware": "^1.0",
        "psr/event-dispatcher": "^1.0",
        "psr/log": "^3.0",
        "psr/container": "^2.0",

        "yiisoft/di": "^1.0",
        "yiisoft/router": "^3.2",
        "yiisoft/config": "^1.0",
        "yiisoft/log": "^2.0",
        "yiisoft/yii-cycle": "2.0.x-dev",
        "yiisoft/console": "^2.3",
        "yiisoft/event-dispatcher": "^1.0",
        "yiisoft/definitions": "^3.4",

        "symfony/console": "^7.2",
        "symfony/uid": "^7.2",

        "cycle/orm": "^2.8",

        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "Opora\\Core\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Opora\\Core\\Tests\\": "tests/"
        }
    },
    "extra": {
        "opora": {
            "migrations": "migrations",
            "namespace": "Opora\\Core\\Migration"
        }
    }
}
